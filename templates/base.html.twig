<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
        <title>{% block title %}Il Grigio Reserveringen{% endblock %}</title>
        
        <!-- Favicon -->
        <link rel="icon" type="image/x-icon" href="{{ asset('images/favicon.ico') }}">
        
        <!-- Tailwind CSS -->
        <script src="https://cdn.tailwindcss.com"></script>
        
        <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

        <!-- iOS Safari ignores user-scalable=no; touch-action disables double-tap zoom -->
        <style>
            html {
                touch-action: manipulation;
                -webkit-text-size-adjust: 100%;
            }
            a, button { cursor: pointer; }
        </style>

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="bg-gray-50 min-h-screen">
        <!-- Main Content -->
        <main>
            {% block body %}{% endblock %}
        </main>

        <!-- Algemene Voorwaarden Modal -->
        <div id="termsModal" class="fixed inset-0 z-50 flex items-center justify-center hidden" aria-modal="true" role="dialog">
            <!-- Backdrop -->
            <div class="absolute inset-0 bg-black bg-opacity-60" onclick="closeTermsModal()"></div>
            <!-- Modal panel -->
            <div class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl mx-4 max-h-[85vh] flex flex-col">
                <!-- Header -->
                <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
                    <h2 class="text-xl font-bold text-gray-800">Algemene Voorwaarden</h2>
                    <button type="button" onclick="closeTermsModal()" class="text-gray-400 hover:text-gray-600 transition-colors" aria-label="Sluiten">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                <!-- Body -->
                <div class="overflow-y-auto px-6 py-6 text-gray-700 leading-relaxed text-sm space-y-4">
                    <h3 class="text-lg font-semibold text-gray-800">Algemene voorwaarden JeugdCircus Il Grigio</h3>
                    <p>
                        Jeugdcircus Il Grigio gebruikt Mollie voor de verwerking van alle online transacties.
                        Uw persoonsgegevens worden in dit kader gedeeld met Mollie en aan haar gelieerde ondernemingen.
                        Wanneer u via onze website uw kaarten reserveert, dan geeft u, direct of indirect, toestemming
                        aan Jeugdcircus Il Grigio, Mollie en aan haar gelieerde ondernemingen, alle vereiste
                        (uitdrukkelijke) toestemmingen als bedoeld in de toepasselijke gegevensbeschermingswetgeving
                        te verwerken.
                    </p>
                </div>
                <!-- Footer -->
                <div class="px-6 py-4 border-t border-gray-200 text-right">
                    <button type="button" onclick="closeTermsModal()" class="bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-5 rounded-lg transition duration-300">
                        Sluiten
                    </button>
                </div>
            </div>
        </div>

        <script>
            function openTermsModal() {
                document.getElementById('termsModal').classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }
            function closeTermsModal() {
                document.getElementById('termsModal').classList.add('hidden');
                document.body.style.overflow = '';
            }
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') closeTermsModal();
            });
        </script>

        <!-- Disable pinch-zoom on iOS Safari, which ignores the viewport scale settings -->
        <script>
            document.addEventListener('gesturestart', function (e) { e.preventDefault(); });
            document.addEventListener('gesturechange', function (e) { e.preventDefault(); });
            document.addEventListener('gestureend', function (e) { e.preventDefault(); });
        </script>

        <!-- Footer -->
        <footer class="bg-gray-800 text-white py-8 mt-12">
            <div class="container mx-auto px-4 text-center">
                <div class="mb-4">
                    <img src="{{ asset('images/Logo-IlGrigioClown.png') }}" alt="Il Grigio" class="h-16 w-auto mx-auto mb-2">
                    <h3 class="text-lg font-semibold">Il Grigio</h3>
                </div>
                
                <!-- Organization Information -->
                <div class="mb-6 text-gray-300 text-sm space-y-1">
                    <p class="font-medium">Stichting Haarens Jeugdcircus Il Grigio</p>
                    <p>E-mail: <a href="mailto:info@ilgrigio.nl" class="text-blue-400 hover:text-blue-300">info@ilgrigio.nl</a></p>
                    <p>BTW: NL006137155B01</p>
                    <p>KvK: 41081727</p>
                    <p>Website: <a href="http://www.ilgrigio.nl" target="_blank" class="text-blue-400 hover:text-blue-300">www.ilgrigio.nl</a></p>
                    <p><button type="button" onclick="openTermsModal()" class="text-blue-400 hover:text-blue-300 underline bg-transparent border-none cursor-pointer text-sm p-0">Algemene Voorwaarden: klik hier</button></p>
                </div>
                
                <!-- Back to Main Website Link -->
                <div class="mb-4">
                    <a href="http://ilgrigio.nl" target="_blank" class="bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg transition duration-300">
                        Terug naar Jeugdcircus Il Grigio
                    </a>
                </div>
            </div>
        </footer>
    </body>
</html>
